{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://mirage-gateway.onrender.com/api/:match*"
    },
    {
      "source": "/ws",
      "destination": "https://mirage-gateway.onrender.com/ws"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Mirage-Protocol", "value": "Initiated" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" }
      ]
    }
  ]
}
